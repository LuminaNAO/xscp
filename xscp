#!/usr/bin/env bash
# xscp - scp wrapper with history, bookmarks, and interactive file picking
# Dependencies: scp, fzf, sshfs (for remote browsing), nnn (optional, fallback to fzf)

set -euo pipefail

HISTORY_FILE="$HOME/.xscp_history"
MOUNT_BASE="/tmp/xscp-mount"
CONTROL_DIR="/tmp/xscp-ctl"
VERSION="0.1.0"

mkdir -p "$CONTROL_DIR"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

# Ensure history file exists
touch "$HISTORY_FILE"

# Track active mounts for cleanup
_XSCP_ACTIVE_MOUNTS=()

_xscp_global_cleanup() {
    for mp in "${_XSCP_ACTIVE_MOUNTS[@]}"; do
        if mountpoint -q "$mp" 2>/dev/null; then
            fusermount -u "$mp" 2>/dev/null || fusermount3 -u "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null || true
        fi
        rmdir "$mp" 2>/dev/null || true
    done
    # Close any control sockets we opened
    for sock in "${CONTROL_DIR}"/*.sock; do
        [[ -e "$sock" ]] || continue
        ssh -o ControlPath="$sock" -O exit dummy 2>/dev/null || true
    done
}
trap _xscp_global_cleanup EXIT INT TERM HUP

# --- Utility functions ---

# --- SSH connection multiplexing ---
# Reuse a single authenticated connection for sshfs + scp

_xscp_ctl_path() {
    local userhost="$1" port="$2"
    echo "${CONTROL_DIR}/${userhost}_${port}.sock"
}

# Open a master connection (authenticates once)
_xscp_ctl_open() {
    local userhost="$1" port="$2"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")
    # Already open?
    if ssh -o ControlPath="$ctl" -O check "$userhost" 2>/dev/null; then
        return 0
    fi
    info "Authenticating to ${userhost}..."
    ssh -o ControlMaster=yes -o ControlPath="$ctl" -o ControlPersist=300 \
        -p "$port" -fN "$userhost"
}

# Close a master connection
_xscp_ctl_close() {
    local userhost="$1" port="$2"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")
    ssh -o ControlPath="$ctl" -O exit "$userhost" 2>/dev/null || true
}

die() { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info() { echo -e "${CYAN}::${NC} $*" >&2; }
warn() { echo -e "${YELLOW}::${NC} $*" >&2; }

check_deps() {
    for cmd in scp fzf; do
        command -v "$cmd" &>/dev/null || die "$cmd is required but not installed"
    done
}

has_nnn() { command -v nnn &>/dev/null; }
has_sshfs() { command -v sshfs &>/dev/null; }

nnn_hint() {
    local mode="${1:-file}"
    echo -e "${CYAN}nnn controls:${NC}" >&2
    echo -e "  ${BOLD}↑↓${NC}/jk  navigate       ${BOLD}→${NC}/l/Enter  open dir" >&2
    echo -e "  ${BOLD}←${NC}/h   parent dir     ${BOLD}.${NC}          toggle hidden files" >&2
    if [[ "$mode" == "dest" ]]; then
        echo -e "  ${BOLD}Space${NC} select highlighted file or folder" >&2
        echo -e "  ${BOLD}q${NC}     select current directory as destination" >&2
    elif [[ "$mode" == "send" ]]; then
        echo -e "  ${BOLD}Space${NC} select highlighted file or folder to send" >&2
        echo -e "  ${BOLD}q${NC}     cancel" >&2
    else
        echo -e "  ${BOLD}Space${NC} select highlighted file" >&2
        echo -e "  ${BOLD}q${NC}     cancel" >&2
    fi
}

# --- History functions ---

# Format: timestamp|direction|user@host:port|remote_path|local_path
history_add() {
    local direction="$1" userhost="$2" port="$3" remote_path="$4" local_path="$5"
    echo "$(date -Iseconds)|${direction}|${userhost}|${port}|${remote_path}|${local_path}" >> "$HISTORY_FILE"
}

history_format_line() {
    local line="$1"
    local ts dir userhost port rpath lpath
    IFS='|' read -r ts dir userhost port rpath lpath <<< "$line"
    local port_str=""
    [[ "$port" != "22" ]] && port_str=" -P ${port}"
    if [[ "$dir" == "send" ]]; then
        echo "[SEND] ${lpath} → ${userhost}:${rpath}${port_str}  (${ts})"
    else
        echo "[RECV] ${userhost}:${rpath} → ${lpath}${port_str}  (${ts})"
    fi
}

history_list() {
    if [[ ! -s "$HISTORY_FILE" ]]; then
        warn "No history yet"
        return 1
    fi
    local lines=()
    while IFS= read -r line; do
        lines+=("$(history_format_line "$line")")
    done < "$HISTORY_FILE"
    # Show in reverse (most recent first)
    for ((i=${#lines[@]}-1; i>=0; i--)); do
        echo "${lines[$i]}"
    done
}

history_pick() {
    local formatted
    formatted=$(history_list) || return 1
    local picked
    picked=$(echo "$formatted" | fzf --height=20 --reverse --prompt="Pick a transfer: ") || return 1
    # Find the matching raw line by matching the timestamp
    local ts
    ts=$(echo "$picked" | grep -oP '\d{4}-\d{2}-\d{2}T[^\)]+')
    grep "$ts" "$HISTORY_FILE" | tail -1
}

history_search() {
    local query="$1"
    local formatted
    formatted=$(history_list) || return 1
    local picked
    picked=$(echo "$formatted" | fzf --height=20 --reverse --query="$query" --prompt="Pick a transfer: ") || return 1
    local ts
    ts=$(echo "$picked" | grep -oP '\d{4}-\d{2}-\d{2}T[^\)]+')
    grep "$ts" "$HISTORY_FILE" | tail -1
}

replay_history_line() {
    local line="$1"
    local ts dir userhost port rpath lpath
    IFS='|' read -r ts dir userhost port rpath lpath <<< "$line"

    info "Replaying: $(history_format_line "$line")"
    echo -ne "${YELLOW}Run this transfer? [Y/n/e(dit)]: ${NC}"
    read -r confirm
    case "$confirm" in
        n|N) info "Cancelled"; return 0 ;;
        e|E)
            # Let user edit before running
            do_${dir} "$userhost" "$port" "$rpath" "$lpath"
            return $?
            ;;
    esac

    _xscp_ctl_open "$userhost" "$port"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")

    local port_args=(-o "ControlPath=${ctl}")
    [[ "$port" != "22" ]] && port_args+=(-P "$port")

    if [[ "$dir" == "send" ]]; then
        info "scp ${port_args[*]:-} ${lpath} ${userhost}:${rpath}"
        scp "${port_args[@]}" "$lpath" "${userhost}:${rpath}"
    else
        info "scp ${port_args[*]:-} ${userhost}:${rpath} ${lpath}"
        scp "${port_args[@]}" "${userhost}:${rpath}" "$lpath"
    fi
    history_add "$dir" "$userhost" "$port" "$rpath" "$lpath"
}

# --- Connection target functions ---

# Get unique user@host entries from history
known_targets() {
    if [[ -s "$HISTORY_FILE" ]]; then
        awk -F'|' '{print $3}' "$HISTORY_FILE" | sort -u
    fi
    # Also pull from ssh config
    if [[ -f "$HOME/.ssh/config" ]]; then
        grep -i "^Host " "$HOME/.ssh/config" 2>/dev/null | awk '{print $2}' | grep -v '[*?]' || true
    fi
}

pick_target() {
    local prompt="${1:-Select remote target: }"
    local targets
    targets=$(known_targets)
    local new_entry="+ New host (enter user@ip)"
    if [[ -n "$targets" ]]; then
        local picked
        picked=$(printf '%s\n' "$new_entry" "$targets" | sort -u | sed "s|^${new_entry}$|${new_entry}|" | { echo "$new_entry"; grep -v "^${new_entry}$" || true; } | fzf --height=15 --reverse --prompt="$prompt") || return 1
        if [[ "$picked" == "$new_entry" ]]; then
            echo -ne "${CYAN}Enter user@host: ${NC}" >&2
            local target
            read -r target < /dev/tty
            [[ -z "$target" ]] && return 1
            echo "$target"
        else
            echo "$picked"
        fi
    else
        echo -ne "${CYAN}Enter user@host: ${NC}" >&2
        local target
        read -r target
        [[ -z "$target" ]] && return 1
        echo "$target"
    fi
}

# Parse user@host or just host, return user@host
parse_target() {
    local target="$1"
    if [[ "$target" == *"@"* ]]; then
        echo "$target"
    else
        echo "${USER}@${target}"
    fi
}

pick_port() {
    local target="$1"
    # Check history for port used with this target
    local hist_port
    hist_port=$(grep "|${target}|" "$HISTORY_FILE" 2>/dev/null | tail -1 | awk -F'|' '{print $4}')
    local default_port="${hist_port:-22}"
    echo -ne "${CYAN}Port [${default_port}]: ${NC}" >&2
    local port
    read -r port
    echo "${port:-$default_port}"
}

# --- File picker functions ---

pick_local_file() {
    local prompt="${1:-Pick local file/dir}"
    local start_dir="${2:-.}"
    info "$prompt"
    if has_nnn; then
        nnn_hint "send"
        local sel
        sel=$(mktemp)
        nnn -p "$sel" "$start_dir" < /dev/tty > /dev/tty
        if [[ -s "$sel" ]]; then
            cat "$sel"
            rm -f "$sel"
        else
            rm -f "$sel"
            return 1
        fi
    else
        # Fallback to fzf
        find "$start_dir" -maxdepth 4 2>/dev/null | fzf --height=20 --reverse --prompt="$prompt: "
    fi
}

pick_local_dest() {
    local prompt="${1:-Pick local destination}"
    local start_dir="${2:-.}"
    info "$prompt (or type a path)"
    if has_nnn; then
        nnn_hint "dest"
        local sel lastdir
        sel=$(mktemp)
        lastdir=$(mktemp)
        # nnn picker mode with last-dir tracking
        NNN_TMPFILE="$lastdir" nnn -p "$sel" "$start_dir" < /dev/tty > /dev/tty
        if [[ -s "$sel" ]]; then
            # User selected a specific item
            cat "$sel"
            rm -f "$sel" "$lastdir"
        elif [[ -s "$lastdir" ]]; then
            # User pressed q - use the last directory they were in
            local dir
            dir=$(cat "$lastdir" | sed "s/^cd ['\"]//;s/['\"]$//")
            echo "$dir"
            rm -f "$sel" "$lastdir"
        else
            rm -f "$sel" "$lastdir"
            echo "$start_dir"
        fi
    else
        echo -ne "${CYAN}Local path [${start_dir}]: ${NC}" >&2
        local path
        read -r path
        echo "${path:-$start_dir}"
    fi
}

# Mount remote filesystem temporarily and let user browse
pick_remote_path() {
    local userhost="$1" port="$2" start_dir="${3:-}"
    local prompt="${4:-Pick remote file/dir}"

    # Default to remote user's home directory
    [[ -z "$start_dir" ]] && start_dir=""

    if ! has_sshfs; then
        # No sshfs - manual entry with path completion hint
        warn "sshfs not installed - enter path manually"
        echo -ne "${CYAN}Remote path: ${NC}" >&2
        local rpath
        read -r rpath
        echo "$rpath"
        return
    fi

    local mountpoint="${MOUNT_BASE}-$$-${RANDOM}"
    mkdir -p "$mountpoint"
    _XSCP_ACTIVE_MOUNTS+=("$mountpoint")

    # Open shared SSH connection (authenticates once)
    _xscp_ctl_open "$userhost" "$port"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")

    info "Mounting ${userhost}:~/ via sshfs..."
    local sshfs_opts="-o reconnect,ServerAliveInterval=15,ServerAliveCountMax=3,ControlPath=${ctl}"
    [[ "$port" != "22" ]] && sshfs_opts="$sshfs_opts -p $port"

    # Mount home directory (empty path = home dir in sshfs)
    if ! sshfs ${sshfs_opts} "${userhost}:" "$mountpoint" 2>/dev/null; then
        warn "Could not mount home dir, trying /"
        if ! sshfs ${sshfs_opts} "${userhost}:/" "$mountpoint" 2>/dev/null; then
            die "sshfs mount failed"
        fi
        start_dir="/"
    else
        start_dir="~"
    fi

    info "$prompt (browsing ${userhost}:${start_dir})"
    local selected
    if has_nnn; then
        nnn_hint "dest"
        local sel lastdir
        sel=$(mktemp)
        lastdir=$(mktemp)
        NNN_TMPFILE="$lastdir" nnn -p "$sel" "$mountpoint" < /dev/tty > /dev/tty
        if [[ -s "$sel" ]]; then
            selected=$(cat "$sel")
            rm -f "$sel" "$lastdir"
        elif [[ -s "$lastdir" ]]; then
            # User pressed q - use the last directory they were in
            # NNN_TMPFILE writes: cd "/path" or cd '/path'
            selected=$(cat "$lastdir" | sed "s/^cd ['\"]//;s/['\"]$//")
            rm -f "$sel" "$lastdir"
        else
            rm -f "$sel" "$lastdir"
            _xscp_unmount "$mountpoint"
            return 1
        fi
    else
        selected=$(find "$mountpoint" -maxdepth 3 2>/dev/null | \
            sed "s|${mountpoint}|${start_dir}/|" | \
            fzf --height=20 --reverse --prompt="$prompt: " | \
            sed "s|${start_dir}/||")
        [[ -z "$selected" ]] && { _xscp_unmount "$mountpoint"; return 1; }
        selected="${mountpoint}${selected}"
    fi

    # Convert mountpoint path(s) back to remote path(s) (one per line)
    local remote_path=""
    while IFS= read -r sel_line; do
        [[ -z "$sel_line" ]] && continue
        local rp="${sel_line#$mountpoint}"
        [[ -z "$rp" ]] && rp=""
        if [[ "$start_dir" == "~" ]]; then
            rp="~${rp}"
        else
            rp="${start_dir%/}${rp}"
        fi
        if [[ -n "$remote_path" ]]; then
            remote_path="${remote_path}"$'\n'"${rp}"
        else
            remote_path="$rp"
        fi
    done <<< "$selected"

    _xscp_unmount "$mountpoint"
    echo "$remote_path"
}

# Unmount a single mountpoint and remove from tracking
_xscp_unmount() {
    local mp="$1"
    if mountpoint -q "$mp" 2>/dev/null; then
        fusermount -u "$mp" 2>/dev/null || fusermount3 -u "$mp" 2>/dev/null || umount -l "$mp" 2>/dev/null || true
    fi
    rmdir "$mp" 2>/dev/null || true
    # Remove from active mounts
    local new_mounts=()
    for m in "${_XSCP_ACTIVE_MOUNTS[@]}"; do
        [[ "$m" != "$mp" ]] && new_mounts+=("$m")
    done
    _XSCP_ACTIVE_MOUNTS=("${new_mounts[@]+"${new_mounts[@]}"}")
}

# --- Transfer functions ---

do_send() {
    local userhost="${1:-}" port="${2:-}" remote_path="${3:-}" local_path="${4:-}"

    # Pick local file if not provided
    if [[ -z "$local_path" ]]; then
        local_path=$(pick_local_file "Pick file/dir to send") || die "No file selected"
    fi
    info "Sending: ${BOLD}${local_path}${NC}"

    # Pick target if not provided
    if [[ -z "$userhost" ]]; then
        local target
        target=$(pick_target "Send to (user@host): ") || die "No target selected"
        userhost=$(parse_target "$target")
    fi

    # Pick port if not provided
    if [[ -z "$port" ]]; then
        port=$(pick_port "$userhost")
    fi

    # Pick remote destination
    if [[ -z "$remote_path" ]]; then
        remote_path=$(pick_remote_path "$userhost" "$port" "" "Pick remote destination") || die "No path selected"
    fi

    # Ensure shared SSH connection is open
    _xscp_ctl_open "$userhost" "$port"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")

    # Build scp command - handle multiple newline-separated local paths
    local scp_args=(-o "ControlPath=${ctl}")
    [[ "$port" != "22" ]] && scp_args+=(-P "$port")
    # Check if any selected path is a directory
    local need_r=false
    while IFS= read -r lp; do
        [[ -z "$lp" ]] && continue
        [[ -d "$lp" ]] && need_r=true
    done <<< "$local_path"
    [[ "$need_r" == true ]] && scp_args+=(-r)
    while IFS= read -r lp; do
        [[ -z "$lp" ]] && continue
        scp_args+=("$lp")
    done <<< "$local_path"
    scp_args+=("${userhost}:${remote_path}")

    # Show full command and confirm
    echo ""
    echo -e "${GREEN}${BOLD}>>>${NC} scp ${scp_args[*]}"
    echo -ne "${YELLOW}Proceed? [Y/n]: ${NC}"
    read -r confirm
    [[ "$confirm" =~ ^[nN] ]] && { info "Cancelled"; return 0; }

    scp "${scp_args[@]}"
    local rc=$?

    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Transfer complete${NC}"
        while IFS= read -r lp; do
            [[ -z "$lp" ]] && continue
            history_add "send" "$userhost" "$port" "$remote_path" "$lp"
        done <<< "$local_path"
    else
        echo -e "${RED}Transfer failed (exit $rc)${NC}"
    fi
    return $rc
}

do_recv() {
    local userhost="${1:-}" port="${2:-}" remote_path="${3:-}" local_path="${4:-}"

    # Pick target if not provided
    if [[ -z "$userhost" ]]; then
        local target
        target=$(pick_target "Receive from (user@host): ") || die "No target selected"
        userhost=$(parse_target "$target")
    fi

    # Pick port if not provided
    if [[ -z "$port" ]]; then
        port=$(pick_port "$userhost")
    fi

    # Pick remote file
    if [[ -z "$remote_path" ]]; then
        remote_path=$(pick_remote_path "$userhost" "$port" "" "Pick remote file/dir to receive") || die "No path selected"
    fi
    info "Receiving: ${BOLD}${userhost}:${remote_path}${NC}"

    # Pick local destination
    if [[ -z "$local_path" ]]; then
        local_path=$(pick_local_dest "Pick local destination" ".") || local_path="."
    fi

    # Ensure shared SSH connection is open
    _xscp_ctl_open "$userhost" "$port"
    local ctl
    ctl=$(_xscp_ctl_path "$userhost" "$port")

    # Build scp command - handle multiple newline-separated remote paths
    # Always pass -r since we can't cheaply check if remote path is a dir
    local scp_args=(-r -o "ControlPath=${ctl}")
    [[ "$port" != "22" ]] && scp_args+=(-P "$port")
    while IFS= read -r rp; do
        [[ -z "$rp" ]] && continue
        scp_args+=("${userhost}:${rp}")
    done <<< "$remote_path"
    scp_args+=("$local_path")

    # Show full command and confirm
    echo ""
    echo -e "${GREEN}${BOLD}>>>${NC} scp ${scp_args[*]}"
    echo -ne "${YELLOW}Proceed? [Y/n]: ${NC}"
    read -r confirm
    [[ "$confirm" =~ ^[nN] ]] && { info "Cancelled"; return 0; }

    scp "${scp_args[@]}"
    local rc=$?

    if [[ $rc -eq 0 ]]; then
        echo -e "${GREEN}Transfer complete${NC}"
        while IFS= read -r rp; do
            [[ -z "$rp" ]] && continue
            history_add "recv" "$userhost" "$port" "$rp" "$local_path"
        done <<< "$remote_path"
    else
        echo -e "${RED}Transfer failed (exit $rc)${NC}"
    fi
    return $rc
}

# --- Main menu ---

main_menu() {
    echo -e "${BOLD}xscp${NC} - interactive scp with history"
    echo ""
    local options=("Send file/dir" "Receive file/dir" "Browse history" "Quit")
    local choice
    choice=$(printf '%s\n' "${options[@]}" | fzf --height=8 --reverse --prompt="What do you want to do? ") || return 0

    case "$choice" in
        "Send file/dir") do_send ;;
        "Receive file/dir") do_recv ;;
        "Browse history")
            local line
            line=$(history_pick) || { warn "No selection"; return 0; }
            replay_history_line "$line"
            ;;
        "Quit") return 0 ;;
    esac
}

# --- Passthrough mode ---
# xscp can also be used as a drop-in scp replacement
do_passthrough() {
    # Parse scp args to extract useful info for history
    local port="22" direction="" userhost="" remote_path="" local_path=""
    local args=("$@")
    local scp_args=()
    local i=0

    while [[ $i -lt ${#args[@]} ]]; do
        case "${args[$i]}" in
            -P)
                port="${args[$((i+1))]}"
                scp_args+=(-P "$port")
                ((i+=2))
                ;;
            -*)
                scp_args+=("${args[$i]}")
                # Handle flags that take a value
                case "${args[$i]}" in
                    -c|-F|-i|-l|-o|-S) scp_args+=("${args[$((i+1))]}"); ((i+=2)) ;;
                    *) ((i+=1)) ;;
                esac
                ;;
            *)
                scp_args+=("${args[$i]}")
                ((i+=1))
                ;;
        esac
    done

    # Try to detect direction from the last two positional args
    local positional=()
    for arg in "${scp_args[@]}"; do
        [[ "$arg" != -* ]] && positional+=("$arg")
    done

    if [[ ${#positional[@]} -ge 2 ]]; then
        local src="${positional[-2]}" dst="${positional[-1]}"
        if [[ "$src" == *:* ]]; then
            direction="recv"
            userhost="${src%%:*}"
            remote_path="${src#*:}"
            local_path="$dst"
        elif [[ "$dst" == *:* ]]; then
            direction="send"
            userhost="${dst%%:*}"
            remote_path="${dst#*:}"
            local_path="$src"
        fi
    fi

    # Run the actual scp
    scp "$@"
    local rc=$?

    # Log to history if we could parse it
    if [[ $rc -eq 0 && -n "$direction" && -n "$userhost" ]]; then
        history_add "$direction" "$userhost" "$port" "${remote_path:-~}" "${local_path:-.}"
    fi
    return $rc
}

# --- Entry point ---

check_deps

case "${1:-}" in
    "")
        main_menu
        ;;
    send)
        shift
        do_send "$@"
        ;;
    recv|receive)
        shift
        do_recv "$@"
        ;;
    history)
        line=$(history_pick) || exit 0
        replay_history_line "$line"
        ;;
    --help|-h)
        echo -e "${BOLD}xscp${NC} v${VERSION} - scp with history and interactive file picking"
        echo ""
        echo "Usage:"
        echo "  xscp                  Interactive menu (send/receive/history)"
        echo "  xscp send             Interactive send flow"
        echo "  xscp recv             Interactive receive flow"
        echo "  xscp history          Browse and replay past transfers"
        echo "  xscp <query>          Fuzzy search history"
        echo "  xscp [scp args...]    Passthrough to scp (logged to history)"
        echo ""
        echo "nnn controls:"
        echo "  ↑↓/jk  navigate       →/l/Enter  open dir"
        echo "  ←/h    parent dir     .          toggle hidden files"
        echo "  Space  select         q          cancel / select dir"
        echo ""
        echo "Dependencies: scp, fzf, nnn, openssh, sshfs (all required)"
        ;;
    --version|-v)
        echo "xscp v${VERSION}"
        ;;
    *)
        # Check if it looks like scp args (contains ':') or a history search
        if printf '%s\n' "$@" | grep -q ':'; then
            do_passthrough "$@"
        else
            line=$(history_search "$1") || exit 0
            replay_history_line "$line"
        fi
        ;;
esac
